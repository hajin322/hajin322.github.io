source "https://rubygems.org"

gem "jekyll", "~> 4.3"

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-scholar"
end

# Windows / JRuby compatibility
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswin]

# Markdown engine
gem "kramdown-parser-gfm"

# Newer Ruby fixes
gem "webrick", "~> 1.8"
gem "csv"
gem "base64"
gem "logger"
