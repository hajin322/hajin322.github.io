@article{hajin2026baipof,
  title   = {Best arm identification with partially observable features in linear bandits},
  author  = {Hajin and Kim, Wonyoung},
  journal = {In preparation, target: Annals of Statistics},
  year    = {2026},
  note    = {Manuscript in preparation},
  abstract = {We study best arm identification (BAI) in linear bandits where
              the feature representation of each arm is only partially
              observed. We propose an algorithm that disentangles the
              observable component from a latent factor and prove a
              fixed-confidence sample complexity bound that scales with the
              effective dimension of the observable subspace.}
}
